# Plantilla de variables de entorno. Copia este archivo a ".env" y rellena el valor real.
# El archivo .env NO se sube a git (está en .gitignore). Tu token es secreto.
#
# Cómo obtener el token en CompanyCam:
#   Settings -> Integrations -> API (o Developer Settings). Requiere plan Pro/Premium/Elite y rol Admin.
#
COMPANYCAM_TOKEN=pega_aqui_tu_token

# Opcional: estado del Google review, métricas, etc. (cuando los tengas)
# PUBLIC_PHONE=(305) 555-0100
