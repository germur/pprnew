---
import { COMPANY, SERVICES } from "../data/company";
const dropdownServices = SERVICES;
---
<!-- UTILITY BAR -->
<div class="util">
  <div class="wrap-wide">
    <div class="util-left">
      <span><i class="dot"></i> 24/7 Emergency Response · IICRC Certified</span>
      <span>IICRC Certified</span>
      <span>Fully Insured &amp; Bonded</span>
      <span>We work with your insurance</span>
    </div>
    <div class="util-right">
      <a href={`tel:${COMPANY.phoneRaw}`}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> {COMPANY.phone}</a>
    </div>
  </div>
</div>

<!-- HEADER -->
<header class="head">
  <div class="wrap-wide head-in">
    <a href="/" class="brand" aria-label={`${COMPANY.name} home`}>
      <img src="/ppr-logo.png" alt="Paramount Property Restoration" width="1024" height="315" style="height:44px;width:auto;display:block;" />
    </a>
    <nav class="nav">
      <div class="has-menu">
        <button>Services <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="dropdown">
          {dropdownServices.map((s) => (
            <a class="dd-item" href={s.url}><span class="t">{s.short} <span class="v">{s.vol === "B2B" ? "B2B" : s.vol + "/mo"}</span></span><span class="d">{s.desc}</span></a>
          ))}
          <div class="dd-foot">
            <span class="num-label">Restoration · water · fire · mold · storm</span>
            <a class="link-arrow" href="/restoration/">All services <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a>
          </div>
        </div>
      </div>
      <a href="/service-areas/">Service Areas</a>
      <a href="/resources/">Resources</a>
      <a href="/commercial/">Commercial</a>
      <a href="/our-process/">Our Process</a>
    </nav>
    <div class="head-cta">
      <div class="head-phone">
        <div class="l">24/7 Emergency</div>
        <div class="n">{COMPANY.phone}</div>
      </div>
      <a href="/emergency/" class="btn btn-alert">Get Help Now</a>
      <button class="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

<!-- MOBILE NAV -->
<div class="mnav">
  <div class="grp">Services</div>
  {SERVICES.filter(s => s.slug !== "commercial").map((s) => (
    <a href={s.url}>{s.short} {s.vol !== "B2B" && <span class="v">{s.vol}</span>}</a>
  ))}
  <div class="grp">Explore</div>
  <a href="/service-areas/">Service Areas</a>
  <a href="/resources/">Resources</a>
  <a href="/commercial/">Commercial</a>
  <a href="/emergency/">Emergency 24/7</a>
</div>
