---
// Iconos de línea finos, consistentes en todo el sitio.
// Uso: <Icon name="water" /> · cambia el grosor con stroke-width vía CSS si hace falta.
// Un solo lugar para todos los iconos: editar aquí los actualiza en toda la web.
export interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: klass = "" } = Astro.props;

const paths: Record<string, string> = {
  // Servicios (uno por pillar)
  water: '<path d="M12 2.7C12 2.7 5 10 5 14.5a7 7 0 0 0 14 0C19 10 12 2.7 12 2.7z"/>',
  mold: '<circle cx="8" cy="9" r="2.6"/><circle cx="15.5" cy="14.5" r="3.6"/><circle cx="9" cy="16" r="1.6"/>',
  fire: '<path d="M12 3c1.5 3 4.5 4.5 4.5 8a4.5 4.5 0 0 1-9 0c0-1.4.6-2.5 1.4-3.3C9.3 9 10 8 10 6.5c1 .8 2 1.7 2-3.5z"/>',
  storm: '<path d="M20 11.5A4.5 4.5 0 0 0 16 7a6 6 0 0 0-11.5 2A4 4 0 0 0 5 17h11"/><path d="M12 13l-2 4h3l-2 4"/>',
  testing: '<path d="M9 3h6M10 3v6L6 18a2 2 0 0 0 1.8 3h8.4A2 2 0 0 0 18 18l-4-9V3"/><path d="M8.5 14h7"/>',
  commercial: '<path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 21v-5h6v5M9 10h.01M15 10h.01M9 13h.01M15 13h.01"/>',
  // Confianza / proceso
  shield: '<path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5z"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  doc: '<path d="M6 2h8l4 4v16H6z"/><path d="M14 2v4h4M9 13h6M9 17h6"/>',
  badge: '<circle cx="12" cy="9" r="5"/><path d="M9 13l-2 8 5-3 5 3-2-8"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>',
  // Pasos / acciones
  inspect: '<circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>',
  dry: '<path d="M3 12h13a3 3 0 1 0-3-3M3 16h17a3 3 0 1 1-3 3M3 8h9"/>',
  check: '<path d="M20 6L9 17l-5-5"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  // Riesgos locales
  wave: '<path d="M2 12c2-2 4-2 6 0s4 2 6 0 4-2 6 0M2 17c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>',
  home: '<path d="M3 11l9-7 9 7M5 10v10h14V10"/>',
  wind: '<path d="M3 8h12a3 3 0 1 0-3-3M3 12h16a3 3 0 1 1-3 3M3 16h9"/>',
};

const d = paths[name] ?? '';
---
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width={size} height={size} class={klass} aria-hidden="true"><Fragment set:html={d} /></svg>
