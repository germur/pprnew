---
import { COMPANY } from "../data/company";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  /** ruta canónica del silo, ej "/restoration/water-damage/" */
  path?: string;
  /** clase extra en <body> (ej "epage" para Emergency) */
  bodyClass?: string;
}
const { title, description, path = "/", bodyClass = "" } = Astro.props;
const canonical = new URL(path, Astro.site).href;

// Schema JSON-LD LocalBusiness, crítico para local pack y rich results.
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": new URL("/", Astro.site).href + "#business",
  name: COMPANY.name,
  description: description,
  url: new URL("/", Astro.site).href,
  telephone: "+1" + COMPANY.phoneRaw,
  email: COMPANY.email,
  image: new URL("/ppr-logo.png", Astro.site).href,
  logo: new URL("/ppr-logo.png", Astro.site).href,
  sameAs: [COMPANY.social.linkedin, COMPANY.social.facebook, COMPANY.social.instagram],
  address: {
    "@type": "PostalAddress",
    streetAddress: COMPANY.address,
    addressLocality: COMPANY.city,
    addressRegion: COMPANY.state,
    postalCode: COMPANY.zip,
    addressCountry: "US",
  },
  areaServed: { "@type": "State", name: "Florida" },
  knowsAbout: ["Water Damage Restoration", "Mold Remediation", "Fire Damage Restoration", "Storm Damage Restoration", "Mold Testing"],
  availableLanguage: ["en", "es"],
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    opens: "00:00", closes: "23:59",
  },
};

// BreadcrumbList derivado del path (rich result de migas en Google).
const CRUMB_NAMES = {
  restoration: "Restoration",
  "service-areas": "Service Areas",
  resources: "Resources",
  commercial: "Commercial",
  contact: "Contact",
  emergency: "Emergency",
  "insurance-claims": "Insurance Claims",
  "our-process": "Our Process",
  "water-damage": "Water Damage Restoration",
  "fire-damage": "Fire & Smoke Damage",
  "mold-remediation": "Mold Remediation",
  "mold-testing": "Mold Testing",
  "storm-damage": "Storm & Hurricane Damage",
  "privacy-policy": "Privacy Policy",
  "terms-of-service": "Terms of Service",
};
const segs = path.split("/").filter(Boolean);
const crumbItems = [{ "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).href }];
let acc = "";
segs.forEach((seg, i) => {
  acc += "/" + seg;
  crumbItems.push({
    "@type": "ListItem",
    position: i + 2,
    name: CRUMB_NAMES[seg] || seg.split("-").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" "),
    item: new URL(acc + "/", Astro.site).href,
  });
});
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: crumbItems };
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/ppr-icon.png" />
  <link rel="apple-touch-icon" href="/ppr-icon.png" />
  <!-- Google Analytics 4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-HW8CW41S53"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-HW8CW41S53');
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={new URL("/ppr-logo.png", Astro.site).href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  {segs.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
</head>
<body class={bodyClass}>
  <Header />
  <slot />
  <Footer />
  <script is:inline src="/app.js"></script>
</body>
</html>
