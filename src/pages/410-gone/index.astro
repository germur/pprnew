---
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "Page no longer available | Paramount Property Restoration";
const description = "This page is no longer available. Explore our water, fire, mold and storm damage restoration services across South Florida.";
---

<BaseLayout title={title} description={description} path="/410-gone/">
<section class="phero"><div class="wrap-wide"><div class="reveal" style="max-width:640px;">
  <span class="eyebrow">410 · Gone</span>
  <h1 class="h1 mt-s">This page is no longer available.</h1>
  <p class="lead mt-m">The page you were looking for has been removed. We now focus on water, fire, mold and storm damage restoration across South Florida.</p>
  <div class="cta-row mt-l">
    <a href="/restoration/" class="btn btn-primary btn-lg">View our services</a>
    <a href="/" class="btn btn-ghost btn-lg">Back to home</a>
  </div>
</div></div></section>
</BaseLayout>
