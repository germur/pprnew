---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { COMPANY } from "../../data/company";

const title = "Contact Paramount Property Restoration | 24/7 South Florida";
const description = "Contact Paramount Property Restoration. Call 24/7 for emergencies or send a message. Serving 15 South Florida cities for water, fire, mold and storm damage.";
---

<BaseLayout title={title} description={description} path="/contact/">
<div class="wrap-wide"><nav class="crumb"><a href="/">Home</a><span>/</span> Contact</nav></div>
<section class="phero"><div class="wrap-wide"><div class="phero-grid">
  <div class="reveal">
    <span class="eyebrow">Contact · 24/7</span>
    <h1 class="display mt-s" style="font-size:clamp(2.6rem,6vw,5rem);">Talk to a real person, <em>any hour.</em></h1>
    <p class="lead maxw mt-m">For active emergencies, calling is fastest, the line is answered live, day or night. For everything else, send the form and we'll get back to you.</p>
    <div class="cta-row mt-l"><a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-primary btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2.5rem;border-top:1px solid var(--line);padding-top:2rem;">
      <div><span class="num-label">Phone · 24/7</span><p style="font-family:var(--serif);font-weight:300;font-size:1.5rem;margin-top:.3rem;">{COMPANY.phone}</p></div>
      <div><span class="num-label">Email</span><p style="font-family:var(--serif);font-weight:300;font-size:1.5rem;margin-top:.3rem;">hello@xxxx.com</p></div>
      <div><span class="num-label">Hours</span><p style="margin-top:.3rem;">Emergency response 24 / 7 / 365<br>Office: Mon–Fri, 8am–6pm</p></div>
      <div><span class="num-label">Service area</span><p style="margin-top:.3rem;">15 cities across South Florida<br><a href="/service-areas/" class="link-arrow" style="font-size:.95rem;">See areas <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a></p></div>
    </div>
  </div>
  <aside class="reveal"><div class="emcard">
    <div class="eyebrow nodash" style="color:#9db8ff;">Send a message</div>
    <h3 class="mt-s">We'll get back to you.</h3>
    <p class="sub">For emergencies, please call, it's faster.</p>
    <hr>
    <form data-emergency class="ef-mini">
      <div style="display:flex;flex-direction:column;gap:.9rem;">
        <div class="field"><label>Your name</label><input type="text" required placeholder="Full name"><span class="msg">Enter your name</span></div>
        <div class="field"><label>Phone</label><input type="tel" required placeholder="(000) 000-0000"><span class="msg">Enter a valid phone</span></div>
        <div class="field"><label>City</label><input type="text" placeholder="e.g. Miami"></div>
        <div class="field"><label>How can we help?</label><select required><option value="">Select…</option><option>Water damage</option><option>Mold</option><option>Fire / smoke</option><option>Storm / hurricane</option><option>Commercial / property management</option><option>Insurance question</option><option>Something else</option></select><span class="msg">Choose one</span></div>
      </div>
      <button class="btn btn-blue btn-block mt-m" type="submit">Send message <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
      <div data-success style="display:none;text-align:center;padding:1rem 0;">
        <svg viewBox="0 0 24 24" fill="none" stroke="#46c37b" stroke-width="2" width="34" height="34" style="margin:0 auto .6rem;"><path d="M20 6L9 17l-5-5"/></svg>
        <p style="color:#fff;font-weight:600;">Message sent.</p>
        <p style="color:#9db8ff;font-size:.9rem;">We'll reply soon. For emergencies, call {COMPANY.phone}.</p>
      </div>
    </form>
  </div></aside>
</div></div></section>
<section class="areas pt pb"><div class="wrap-wide reveal">
  <span class="eyebrow">Where we are</span>
  <h2 class="h2 mt-s" style="max-width:24ch;">Crews staged across South Florida.</h2>
  <div class="ph ph-blue mt-m" data-ph="Map, service footprint across Southwest, Treasure Coast & Southeast Florida" style="aspect-ratio:21/7;border-radius:var(--radius);"></div>
</div></section>
<section class="emcta"><div class="wrap-wide emcta-in reveal">
  <div><span class="eyebrow nodash" style="color:#ffd2c4;">Emergency?</span><h2 class="display" style="color:#fff;max-width:16ch;">Don't fill a form, call us now.</h2></div>
  <div class="emcta-actions"><a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-lg" style="background:#fff;color:var(--alert);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a><a href="/emergency/" class="btn btn-lg btn-block" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5);">Emergency request <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
</div></section>
</BaseLayout>
