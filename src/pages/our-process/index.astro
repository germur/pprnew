---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { COMPANY , REGIONS } from "../../data/company";

const title = "Our Restoration Process | Paramount";
const description = "The documented Paramount restoration process: 24/7 dispatch, inspection, mitigation, structural drying and verified restoration. IICRC-certified, insurance handled.";
---

<BaseLayout title={title} description={description} path="/our-process/">
<div class="wrap-wide"><nav class="crumb"><a href="/">Home</a><span>/</span> Our Process</nav></div>
<section class="phero"><div class="wrap-wide"><div class="reveal" style="max-width:60ch;">
  <span class="eyebrow">How we work</span>
  <h1 class="display mt-s" style="font-size:clamp(2.6rem,6vw,5rem);">A method, not a <em>guess.</em></h1>
  <p class="lead maxw mt-m">Restoration done right is a documented sequence, inspect, mitigate, dry, verify, restore. Here is exactly what happens from your first call to the day we hand your property back.</p>
</div></div></section>
<section class="trust"><div class="wrap-wide"><div class="trust-grid">
  <div class="trust-item reveal"><div class="metric-sm">Fast</div><span class="num-label" style="margin-top:.4rem;display:block;">24/7 emergency response</span></div>
  <div class="trust-item reveal"><div class="metric-sm">Daily</div><span class="num-label" style="margin-top:.4rem;display:block;">Moisture monitoring visits</span></div>
  <div class="trust-item reveal"><div class="metric-sm">IICRC</div><span class="num-label" style="margin-top:.4rem;display:block;">Certified to industry standard</span></div>
  <div class="trust-item reveal"><div class="metric-sm">1 team</div><span class="num-label" style="margin-top:.4rem;display:block;">Start to finish, accountable</span></div>
</div></div></section>
<section class="pt pb"><div class="wrap-wide">
  <div class="sec-head reveal"><div><span class="eyebrow">The five steps</span><h2 class="h2 mt-s" style="max-width:18ch;">Every job follows the same path.</h2></div></div>
  <div class="steps mt-l">
    <div class="step reveal"><div class="n">01 / Call</div><div><h3 class="h3">Call &amp; dispatch</h3><div class="sd"><p>One number, answered live 24/7. We log the emergency and send the nearest certified crew right away.</p><p>No phone trees, no callbacks during an emergency. A real dispatcher gets you moving.</p></div></div></div>
    <div class="step reveal"><div class="n">02 / Inspect</div><div><h3 class="h3">Inspect &amp; document</h3><div class="sd"><p>We trace the source and map every affected material with moisture meters and thermal imaging.</p><p>Each reading is photographed and logged, the foundation of a clean insurance claim.</p></div></div></div>
    <div class="step reveal"><div class="n">03 / Mitigate</div><div><h3 class="h3">Mitigate &amp; stabilize</h3><div class="sd"><p>Extraction, containment, tarping or board-up, whatever stops the damage from spreading right now.</p><p>Speed here is what turns a dry-out into a save instead of a rebuild.</p></div></div></div>
    <div class="step reveal"><div class="n">04 / Dry</div><div><h3 class="h3">Dry &amp; monitor</h3><div class="sd"><p>Commercial air movers and dehumidifiers pull moisture from structure and contents.</p><p>We return daily, measure progress, and adjust until readings hit dry standard, the step that prevents mold.</p></div></div></div>
    <div class="step reveal"><div class="n">05 / Restore</div><div><h3 class="h3">Restore &amp; verify</h3><div class="sd"><p>Drywall, flooring and finishes brought back to pre-loss condition by the same accountable team.</p><p>We verify dryness and walk you through the result before we close the file.</p></div></div></div>
  </div>
</div></section>
<section class="insight"><div class="wrap-wide"><div class="insight-in reveal">
  <span class="eyebrow nodash" style="color:#9db8ff;">Why the order matters</span>
  <p class="h2" style="color:#fff;max-width:24ch;">Skip a step and the damage <em>comes back.</em></p>
  <p class="lead" style="color:#aac3ff;max-width:46ch;">Painting over a wet wall, or "drying" without verification, is how a water loss becomes a mold problem weeks later. We follow the sequence so you only pay for the disaster once.</p>
  <a href="/restoration/water-damage/" class="link-arrow" style="color:#fff;">See it applied to water damage <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a>
</div></div></section>
<section class="pt pb areas"><div class="wrap-wide reveal">
  <span class="eyebrow">Credentials</span>
  <h2 class="h2 mt-s" style="max-width:24ch;">What stands behind the method.</h2>
  <div class="citylinks mt-m">{REGIONS.flatMap((r) => r.cities).map((c) => (<a href={`/service-areas/${c.slug}/`}>{c.name}</a>))}</div>
  <p class="body-l mt-m" style="max-width:60ch;">Restoration only, water, fire, mold and storm. We are not a general contractor and don't perform remodeling or new construction; we restore properties to pre-loss condition and document every step for your carrier.</p>
</div></section>

<section class="emcta">
  <div class="wrap-wide emcta-in reveal">
    <div>
      <span class="eyebrow nodash" style="color:#ffd2c4;">24/7 Emergency Response</span>
      <h2 class="display" style="color:#fff;max-width:16ch;">A certified crew is one call away.</h2>
    </div>
    <div class="emcta-actions">
      <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-lg" style="background:#fff;color:var(--alert);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
      <a href="/emergency/" class="btn btn-lg btn-block" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5);">Request help online <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </div>
</section>
</BaseLayout>
