---
import BaseLayout from "../layouts/BaseLayout.astro";
import { COMPANY, REGIONS, CITY_COUNT } from "../data/company";
import Icon from "../components/Icon.astro";

const title = "Paramount Property Restoration | South Florida Water, Fire, Mold & Storm";
const description = "South Florida's 24/7 restoration company. Water damage, mold remediation, fire & storm restoration. IICRC-certified, fully insured, insurance handled. On-site in 60 minutes.";
---

<BaseLayout title={title} description={description} path="/">
<!-- ============ HERO ============ -->
<section class="hero pt">
  <div class="wrap-wide">
    <div class="hero-grid">
      <div class="hero-copy reveal">
        <span class="eyebrow">Property Restoration · South Florida</span>
        <h1 class="display">When water, fire or&nbsp;mold strikes, <em>every hour</em> decides the outcome.</h1>
        <p class="lead maxw mt-m">Paramount is South Florida's around-the-clock restoration response. <strong>IICRC-certified crews, insurance handled end to end, on-site in 60 minutes.</strong></p>
        <div class="cta-row mt-l">
          <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-primary btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
          <a href="/emergency/" class="btn btn-ghost btn-lg">Request emergency help <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
      </div>
      <aside class="hero-side reveal">
        <div class="hero-stat">
          <div class="metric">60<span style="font-size:.4em;font-family:var(--sans);font-weight:600;">min</span></div>
          <div class="num-label">Average on-site response</div>
        </div>
        <hr class="rule">
        <div class="hero-stat">
          <div class="metric">24/7</div>
          <div class="num-label">Emergency dispatch, 365 days</div>
        </div>
        <hr class="rule">
        <div class="hero-stat">
          <div class="metric">IICRC</div>
          <div class="num-label">Certified restoration crews</div>
        </div>
      </aside>
    </div>
  </div>
  <div class="wrap-wide">
    <div class="hero-img ph" data-ph="Full-bleed photo: crew on-site, drying equipment in a flooded South Florida home" style="aspect-ratio:24/9;margin-top:clamp(2.5rem,5vw,4.5rem);"></div>
  </div>
</section>

<!-- ============ TRUST STRIP ============ -->
<section class="trust">
  <div class="wrap-wide">
    <div class="trust-grid">
      <div class="trust-item reveal"><span class="trust-ico"><Icon name="doc" size={22} /></span><span class="num-label">Insurance</span><p>We bill your carrier directly and document every step for the claim.</p></div>
      <div class="trust-item reveal"><span class="trust-ico"><Icon name="badge" size={22} /></span><span class="num-label">Certification</span><p>IICRC-certified technicians in water, fire, mold &amp; applied structural drying.</p></div>
      <div class="trust-item reveal"><span class="trust-ico"><Icon name="shield" size={22} /></span><span class="num-label">Coverage</span><p>Fully insured &amp; bonded, with verifiable credentials and no contractor overreach.</p></div>
      <div class="trust-item reveal"><span class="trust-ico"><Icon name="check" size={22} /></span><span class="num-label">Local</span><p>Real crews based in South Florida, documenting every loss for your insurer.</p></div>
    </div>
  </div>
</section>

<!-- ============ SERVICES ============ -->
<section class="pt pb" id="services">
  <div class="wrap-wide">
    <div class="sec-head reveal">
      <div>
        <span class="eyebrow">01 · What we restore</span>
        <h2 class="h2 mt-s" style="max-width:18ch;">Four disasters. One certified response across South Florida.</h2>
      </div>
      <p class="body-l" style="max-width:34ch;">Every page below is a real service we perform. No doorway pages, no city-by-service filler. Demand figures are monthly U.S. search volume from the validated SEO blueprint.</p>
    </div>

    <div class="svc-grid mt-l">
      <a href="/restoration/water-damage/" class="svc reveal">
        <div class="svc-media ph ph-blue" data-ph="Water extraction & structural drying"><span class="svc-icon"><Icon name="water" size={26} /></span></div>
        <div class="svc-body">
          <div class="svc-top"><span class="num-label">/restoration/water-damage</span><span class="svc-vol">135K<small> + 246K near-me</small></span></div>
          <h3 class="h3">Water Damage Restoration</h3>
          <p>Burst pipes, roof leaks, flooding. We extract, dry and restore, then stop the mold that follows.</p>
          <span class="link-arrow">Explore water damage <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></span>
        </div>
      </a>
      <a href="/restoration/mold-remediation/" class="svc reveal">
        <div class="svc-media ph" data-ph="Mold containment & remediation"><span class="svc-icon"><Icon name="mold" size={26} /></span></div>
        <div class="svc-body">
          <div class="svc-top"><span class="num-label">/restoration/mold-remediation</span><span class="svc-vol">165K<small> + 60K near-me</small></span></div>
          <h3 class="h3">Mold Remediation</h3>
          <p>Containment, HEPA filtration, removal and third-party clearance. Built for Florida humidity.</p>
          <span class="link-arrow">Explore mold remediation <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></span>
        </div>
      </a>
      <a href="/restoration/fire-damage/" class="svc reveal">
        <div class="svc-media ph" data-ph="Fire, soot & smoke recovery"><span class="svc-icon"><Icon name="fire" size={26} /></span></div>
        <div class="svc-body">
          <div class="svc-top"><span class="num-label">/restoration/fire-damage</span><span class="svc-vol">135K<small> + 49K near-me</small></span></div>
          <h3 class="h3">Fire &amp; Smoke Damage</h3>
          <p>Soot and smoke removal, odor neutralization and contents recovery, plus the water from firefighting.</p>
          <span class="link-arrow">Explore fire damage <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></span>
        </div>
      </a>
      <a href="/restoration/storm-damage/" class="svc reveal">
        <div class="svc-media ph ph-blue" data-ph="Storm, hurricane & water intrusion"><span class="svc-icon"><Icon name="storm" size={26} /></span></div>
        <div class="svc-body">
          <div class="svc-top"><span class="num-label">/restoration/storm-damage</span><span class="svc-vol">110K<small> + 60K near-me</small></span></div>
          <h3 class="h3">Storm &amp; Hurricane Damage</h3>
          <p>Emergency tarping, water intrusion, debris and full structural restoration after the season's worst.</p>
          <span class="link-arrow">Explore storm damage <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></span>
        </div>
      </a>
    </div>

    <div class="svc-row mt-m">
      <a href="/restoration/mold-testing/" class="svc-mini reveal">
        <span class="svc-mini-ico"><Icon name="testing" size={24} /></span>
        <div><span class="num-label">/restoration/mold-testing · 66K</span><h3 class="h3" style="margin-top:.3rem;">Mold Testing &amp; Inspection</h3></div>
        <p>Independent inspection and lab analysis, before you commit to remediation.</p>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
      </a>
      <a href="/commercial/" class="svc-mini reveal">
        <span class="svc-mini-ico"><Icon name="commercial" size={24} /></span>
        <div><span class="num-label">/commercial · B2B</span><h3 class="h3" style="margin-top:.3rem;">Commercial Restoration</h3></div>
        <p>Large-loss response for property managers, HOAs and businesses.</p>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ============ CROSS-LINK INSIGHT ============ -->
<section class="insight">
  <div class="wrap-wide">
    <div class="insight-in reveal">
      <span class="eyebrow nodash" style="color:#9db8ff;">The connection most companies miss</span>
      <p class="h2" style="color:#fff;max-width:24ch;">Water damage today becomes a <em>mold problem</em> in two to three weeks.</p>
      <p class="lead" style="color:#aac3ff;max-width:46ch;">That's why we don't just dry your property. We monitor moisture to clearance standards and tell you, honestly, whether testing is warranted. One emergency, handled to the end.</p>
      <a href="/restoration/mold-remediation/" class="link-arrow" style="color:#fff;">See how water leads to mold <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a>
    </div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section class="pt pb" id="process">
  <div class="wrap-wide">
    <div class="sec-head reveal">
      <div><span class="eyebrow">02 · How it works</span><h2 class="h2 mt-s" style="max-width:16ch;">From the first call to a property made whole.</h2></div>
    </div>
    <div class="proc-grid mt-l">
      <div class="proc reveal"><div class="proc-no">01</div><h3 class="h3">Call &amp; dispatch</h3><p>One call, day or night. We dispatch a certified crew to arrive within 60 minutes.</p></div>
      <div class="proc reveal"><div class="proc-no">02</div><h3 class="h3">Assess &amp; document</h3><p>We inspect, photograph and scope the damage, building the file your insurer needs.</p></div>
      <div class="proc reveal"><div class="proc-no">03</div><h3 class="h3">Mitigate &amp; dry</h3><p>Extraction, containment and structural drying to stop the damage from spreading.</p></div>
      <div class="proc reveal"><div class="proc-no">04</div><h3 class="h3">Restore &amp; verify</h3><p>We restore to pre-loss condition and verify to clearance standards before we leave.</p></div>
    </div>
  </div>
</section>

<!-- ============ PRODUCT-LED PROJECTS ============ -->
<section class="pb">
  <div class="wrap-wide">
    <div class="sec-head reveal">
      <div><span class="eyebrow">03 · Recent work</span><h2 class="h2 mt-s" style="max-width:20ch;">Real South Florida projects, documented.</h2></div>
      <p class="body-l" style="max-width:34ch;">Drag the handle to see before and after. Every project is a real loss our crews restored: the proof that ranks, and the proof that converts.</p>
    </div>
    <div class="proj-grid mt-l">
      <figure class="proj reveal">
        <div class="ba" data-ba>
          <div class="ph ba-before" data-ph="AFTER: restored living room, Coral Gables"></div>
          <div class="ph ph-ink ba-after" data-ph="BEFORE: flood damage"></div>
          <div class="ba-handle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg></div>
        </div>
        <figcaption><span class="num-label">Water · Coral Gables</span><p>Pipe burst, 2-story water intrusion. Dried and restored to pre-loss condition.</p></figcaption>
      </figure>
      <figure class="proj reveal">
        <div class="ba" data-ba>
          <div class="ph ba-before" data-ph="AFTER: clean attic, Naples"></div>
          <div class="ph ph-ink ba-after" data-ph="BEFORE: mold growth"></div>
          <div class="ba-handle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg></div>
        </div>
        <figcaption><span class="num-label">Mold · Naples</span><p>Post-leak mold. Contained, removed &amp; cleared to lab standard.</p></figcaption>
      </figure>
      <figure class="proj reveal">
        <div class="ba" data-ba>
          <div class="ph ba-before" data-ph="AFTER: repaired roof & ceiling, Miami"></div>
          <div class="ph ph-ink ba-after" data-ph="BEFORE: storm damage"></div>
          <div class="ba-handle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/></svg></div>
        </div>
        <figcaption><span class="num-label">Storm · Miami</span><p>Hurricane water intrusion. Tarped same-day, fully restored.</p></figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- ============ SERVICE AREAS ============ -->
<section class="areas pt pb">
  <div class="wrap-wide">
    <div class="sec-head reveal">
      <div><span class="eyebrow">04 · Where we work</span><h2 class="h2 mt-s" style="max-width:20ch;">{CITY_COUNT} South Florida cities. <em>Real</em> local crews.</h2></div>
      <p class="body-l" style="max-width:34ch;">We only claim cities where we actually operate, with local projects, response times and storm-risk knowledge. No filler pages for towns we don't serve.</p>
    </div>
    <div class="areas-grid mt-l reveal">
      {REGIONS.map((region) => (
        <div class="area-col">
          <h4 class="num-label">{region.name}</h4>
          <ul>
            {region.cities.map((city) => (
              <li>
                <a href={`/service-areas/${city.slug}/`} class={city.slug === "miami" ? "city-feat" : undefined}>
                  {city.name}{city.slug === "miami" ? " →" : ""}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <div class="area-map ph ph-blue" data-ph="Map of South Florida coverage: Southwest, Treasure Coast & Southeast regions"></div>
    </div>
  </div>
</section>

<!-- ============ INSURANCE BAND ============ -->
<section class="insure pb">
  <div class="wrap-wide">
    <div class="insure-in reveal">
      <div>
        <span class="eyebrow">Insurance, handled</span>
        <h2 class="h2 mt-s" style="max-width:18ch;">We speak your insurer's language, so you don't have to.</h2>
        <p class="lead maxw mt-m">From the first photo to the final invoice, we document the loss and bill your carrier directly. You focus on your family; we handle the claim.</p>
        <a href="/emergency/" class="btn btn-blue btn-lg mt-m">Start an insurance claim <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
      <ul class="insure-list">
        <li><span class="num-label">01</span> Direct insurance billing &amp; carrier coordination</li>
        <li><span class="num-label">02</span> Photo &amp; moisture documentation for every claim</li>
        <li><span class="num-label">03</span> Detailed scope &amp; line-item estimates</li>
        <li><span class="num-label">04</span> Fully insured &amp; bonded, credentials on request</li>
      </ul>
    </div>
  </div>
</section>

<!-- ============ RESOURCES TEASER ============ -->
<section class="pb">
  <div class="wrap-wide">
    <div class="sec-head reveal">
      <div><span class="eyebrow">05 · Resources</span><h2 class="h2 mt-s" style="max-width:18ch;">Answers before the emergency.</h2></div>
      <a href="/resources/is-black-mold-dangerous/" class="link-arrow">Read the guides <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a>
    </div>
    <div class="res-grid mt-l">
      <a href="/resources/is-black-mold-dangerous/" class="res reveal"><span class="num-label">Mold · 6.6K/mo</span><h3 class="h3">Is black mold dangerous?</h3><p>What's true, what's hype, and when to call a professional.</p></a>
      <a href="/resources/is-black-mold-dangerous/" class="res reveal"><span class="num-label">Water · TOFU</span><h3 class="h3">What to do after water damage</h3><p>The first 24 hours that decide your repair bill.</p></a>
      <a href="/resources/is-black-mold-dangerous/" class="res reveal"><span class="num-label">Storm · seasonal</span><h3 class="h3">What to do after a hurricane</h3><p>A homeowner's step-by-step recovery checklist.</p></a>
    </div>
  </div>
</section>

<!-- ============ EMERGENCY CTA ============ -->
<section class="emcta">
  <div class="wrap-wide emcta-in reveal">
    <div>
      <span class="eyebrow nodash" style="color:#ffd2c4;">24/7 Emergency Response</span>
      <h2 class="display" style="color:#fff;max-width:16ch;">If you're reading this, something went wrong today.</h2>
      <p class="lead" style="color:#ffd9cd;max-width:42ch;" class="mt-m">Don't wait for the damage to spread. Call now or send a request, and a certified crew is on the way.</p>
    </div>
    <div class="emcta-actions">
      <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-lg" style="background:#fff;color:var(--alert);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
      <a href="/emergency/" class="btn btn-lg btn-block" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5);">Request help online <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </div>
</section>
</BaseLayout>
