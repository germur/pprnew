---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { COMPANY, REGIONS, SERVICES } from "../../data/company";
import { CITY_CONTENT } from "../../data/cities-content";
import Icon from "../../components/Icon.astro";
import companycam from "../../data/companycam.json";

// Genera una página por cada ciudad del sheet (15 en total).
export function getStaticPaths() {
  const paths = [];
  for (const region of REGIONS) {
    for (const city of region.cities) {
      paths.push({
        params: { city: city.slug },
        props: { city, regionName: region.name },
      });
    }
  }
  return paths;
}

const { city, regionName } = Astro.props;
const serviceCards = SERVICES.filter((s) => s.slug !== "commercial");
// Contenido local único si existe; si no, la sección muestra un placeholder.
const local = CITY_CONTENT[city.slug];
// Fotos reales de proyectos en esta ciudad (CompanyCam). Máximo 6 en la galería.
const cityPhotos = ((companycam as Record<string, { src: string; alt: string; projectName: string }[]>)[city.slug] || []).slice(0, 6);
const title = `${city.name} Restoration | Water, Fire, Mold & Storm | Paramount`;
const description = `24/7 property restoration in ${city.name}, FL. Water damage, mold, fire and storm recovery by local IICRC-certified crews. On-site in 60 minutes, insurance handled.`;
---

<BaseLayout title={title} description={description} path={`/service-areas/${city.slug}/`}>
  <div class="wrap-wide"><nav class="crumb"><a href="/">Home</a><span>/</span><a href="/service-areas/">Service Areas</a><span>/</span> {city.name}</nav></div>

  <section class="phero">
    <div class="wrap-wide">
      <div class="phero-grid">
        <div class="reveal">
          <span class="eyebrow">Local restoration · {regionName}</span>
          <h1 class="h1 mt-s">Property Restoration in {city.name}, Florida</h1>
          <p class="empathy">When disaster hits your {city.name} property, every hour counts. We answer day or night.</p>
          <p class="lead maxw mt-m">Water, fire, mold and storm damage handled by crews that actually work {city.name}. <strong>On-site in 60 minutes, insurance handled end to end.</strong></p>
          <div class="cta-row mt-l">
            <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-primary btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
            <a href="/emergency/" class="btn btn-ghost btn-lg">Request help <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </div>
        </div>
        <aside class="reveal">
          <div class="ph ph-blue" data-ph={`Map: ${city.name} coverage area`} style="aspect-ratio:4/3;border-radius:var(--radius);"></div>
          <div class="trust-grid" style="grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1.5rem;">
            <div><div class="metric-sm">~60min</div><span class="num-label">Avg arrival in {city.name}</span></div>
            <div><div class="metric-sm">XX+</div><span class="num-label">Projects in {regionName}</span></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- SERVICES IN CITY -->
  <section class="pt pb">
    <div class="wrap-wide">
      <div class="sec-head reveal">
        <div><span class="eyebrow">01 · Services in {city.name}</span><h2 class="h2 mt-s" style="max-width:20ch;">Every restoration service, right here in {city.name}.</h2></div>
        <p class="body-l" style="max-width:32ch;">One local crew for all four disasters. No handoffs, no out-of-town subcontractors.</p>
      </div>
      <div class="types mt-l">
        {serviceCards.map((s) => (
          <a class="type reveal" href={s.url}>
            <Icon name={s.icon} class="ico" size={30} />
            <span class="num-label" style="color:var(--blue)">{s.short}</span>
            <h3>{s.short} in {city.name}</h3>
            <p>{s.desc}.</p>
            <span class="link-arrow" style="margin-top:auto;">{s.short} in {city.name} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL CONTENT: contenido único por ciudad (test de 300 palabras del sheet). -->
  <section class="insure pb">
    <div class="wrap-wide">
      <div class="insure-in reveal" style="align-items:start;">
        <div class="prose">
          <span class="eyebrow">02 · Why {city.name} is different</span>
          <h2 class="h2 mt-s" style="max-width:20ch;">Restoration built for {city.name}'s climate.</h2>
          {local ? (
            local.intro.map((para) => <p class="mt-m">{para}</p>)
          ) : (
            <p class="mt-m">{city.name} faces the same Florida realities every property here knows: high humidity, an active hurricane season, and water that turns to mold fast when it is not dried correctly. Our local crews respond across {regionName}, document each loss for your insurer, and prioritize the drying timeline so a manageable loss never becomes a full rebuild.</p>
          )}
          {local && local.neighborhoods.length > 0 && (
            <p class="mt-m"><strong>Areas we serve in {city.name}:</strong> {local.neighborhoods.join(", ")}.</p>
          )}
        </div>
        <div>
          <div class="pullcard"><span class="num-label">Local risk</span><p style="font-family:var(--serif);font-weight:300;font-size:1.5rem;line-height:1.3;margin-top:.5rem;color:var(--ink);">{local ? local.riskHeadline : "Florida humidity and hurricane season make fast drying non-negotiable."}</p></div>
          <ul class="risk-list" style="margin-top:1rem;">
            {(local ? local.risks : ["Coastal and storm-surge flooding","Humidity-driven mold growth","Hurricane wind and roof damage","Water intrusion in local building stock"]).map((risk) => (
              <li><span class="risk-ico"><Icon name="wave" size={18} /></span> {risk}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {cityPhotos.length > 0 && (
    <!-- REAL PROJECTS (CompanyCam) -->
    <section class="pb">
      <div class="wrap-wide">
        <div class="sec-head reveal">
          <div><span class="eyebrow">03 · Recent work</span><h2 class="h2 mt-s" style="max-width:20ch;">Real {city.name} projects, documented.</h2></div>
          <p class="body-l" style="max-width:32ch;">Actual restoration work our crews completed in {city.name}. The proof that ranks, and the proof that converts.</p>
        </div>
        <div class="cc-grid mt-l">
          {cityPhotos.map((photo) => (
            <figure class="cc-item reveal">
              <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" width="600" height="450" />
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- EMERGENCY CTA -->
  <section class="emcta">
    <div class="wrap-wide emcta-in reveal">
      <div><span class="eyebrow nodash" style="color:#ffd2c4;">24/7 in {city.name}</span><h2 class="display" style="color:#fff;max-width:16ch;">Damage in {city.name}? Call now.</h2></div>
      <div class="emcta-actions">
        <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-lg" style="background:#fff;color:var(--alert);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
        <a href="/emergency/" class="btn btn-lg btn-block" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5);">Request help online <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>
</BaseLayout>
