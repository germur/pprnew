---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { COMPANY } from "../../data/company";

const title = "Service Areas | 35 South Florida Cities | Paramount";
const description = "Paramount serves 35 South Florida cities across Southwest, Treasure Coast and Southeast Florida with local crews and 24/7 response.";
---

<BaseLayout title={title} description={description} path="/service-areas/">
<div class="wrap-wide"><nav class="crumb"><a href="/">Home</a><span>/</span> Service Areas</nav></div>
<section class="phero"><div class="wrap-wide"><div class="phero-grid">
  <div class="reveal">
    <span class="eyebrow">Where we work · Product-Led local</span>
    <h1 class="display mt-s" style="font-size:clamp(2.6rem,6vw,5rem);">35 South Florida cities. <em>Real</em> local crews.</h1>
    <p class="lead maxw mt-m">We only claim the places we actually serve, with local projects, response times and storm-risk knowledge. Pick your city below.</p>
    <div class="cta-row mt-l"><a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-primary btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a><a href="/emergency/" class="btn btn-ghost btn-lg">Request help <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>
  </div>
  <aside class="reveal"><div class="area-map" style="aspect-ratio:4/5;border-radius:var(--radius);"><img src="/heroes/map-coverage.webp" alt="Map of Paramount Property Restoration coverage across Southwest, Treasure Coast and Southeast Florida" width="512" height="512" loading="lazy" decoding="async" /></div></aside>
</div></div></section>
<section class="pt pb"><div class="wrap-wide">
  <div class="sec-head reveal"><div><span class="eyebrow">Southwest Florida</span><h2 class="h2 mt-s">Gulf coast &amp; the islands</h2></div></div>
  <div class="rel-grid mt-l"><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Naples</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Fort Myers</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Bonita Springs</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Estero</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Cape Coral</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Marco Island</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a></div>
  <div class="sec-head reveal" style="margin-top:clamp(3rem,5vw,4rem);"><div><span class="eyebrow">Treasure Coast</span><h2 class="h2 mt-s">Atlantic, north of the metro</h2></div></div>
  <div class="rel-grid mt-l"><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Port St. Lucie</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Hobe Sound</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a></div>
  <div class="sec-head reveal" style="margin-top:clamp(3rem,5vw,4rem);"><div><span class="eyebrow">Southeast Florida</span><h2 class="h2 mt-s">The metro &amp; the Gold Coast</h2></div></div>
  <div class="rel-grid mt-l"><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Miami</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Coral Gables</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Fort Lauderdale</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Deerfield Beach</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Boca Raton</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">Delray Beach</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a><a href="/service-areas/miami/" class="rel reveal"><div><span class="num-label">Restoration · 24/7</span><h3 style="margin-top:.3rem;">West Palm Beach</h3></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg></a></div>
</div></section>
<section class="insure pb"><div class="wrap-wide"><div class="insure-in reveal">
  <div>
    <span class="eyebrow">How local works</span>
    <h2 class="h2 mt-s" style="max-width:18ch;">A real crew nearby beats a dispatch two counties away.</h2>
    <p class="lead maxw mt-m">Each city page carries genuine local detail, projects we've done, the neighborhoods we cover and the risks specific to that area. If we can't write it honestly, it's grouped into a region until we can.</p>
    <a href="/service-areas/miami/" class="btn btn-blue btn-lg mt-m">See an example: Miami <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
  </div>
  <ul class="insure-list"><li><span class="num-label">→</span> Local projects &amp; before/after proof</li><li><span class="num-label">→</span> Neighborhood-level coverage</li><li><span class="num-label">→</span> Area-specific storm &amp; flood risk</li><li><span class="num-label">→</span> Honest 24/7 response promise</li></ul>
</div></div></section>

<section class="emcta">
  <div class="wrap-wide emcta-in reveal">
    <div>
      <span class="eyebrow nodash" style="color:#ffd2c4;">24/7 Emergency Response</span>
      <h2 class="display" style="color:#fff;max-width:16ch;">A certified crew is one call away.</h2>
    </div>
    <div class="emcta-actions">
      <a href={`tel:${COMPANY.phoneRaw}`} class="btn btn-lg" style="background:#fff;color:var(--alert);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Call {COMPANY.phone}</a>
      <a href="/emergency/" class="btn btn-lg btn-block" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.5);">Request help online <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </div>
</section>
</BaseLayout>
